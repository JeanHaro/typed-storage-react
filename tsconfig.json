{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020", "DOM"],
        "strict": true,
        "esModuleInterop": true,
        "jsx": "react",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationDir": "./dist",
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*"]
}